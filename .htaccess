# ============================================================
#  Core Web Pro — Apache performance & caching rules
# ============================================================
#
#  Domain setup:
#    Primary  → corewebpro.in   (files hosted here)
#    Alias    → corewebpro.com  (parked/addon domain, same document root)
#
#  Both domains serve the same files.
#  www is stripped on both domains.
#  HTTP is upgraded to HTTPS on both domains.
# ============================================================

Options -Indexes

# ── Domain routing: www removal + HTTPS enforcement ──────────
#
#  Handles all four entry points for each domain:
#    http://www.domain   → https://domain  (2 hops, or 1 if combined below)
#    https://www.domain  → https://domain
#    http://domain       → https://domain
#    https://domain      → served as-is  ✓
#
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Step 1 — Strip www from any domain (corewebpro.in or corewebpro.com).
    #           Redirect target is always HTTPS non-www of the SAME domain,
    #           so .in stays .in and .com stays .com.
    RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
    RewriteRule ^ https://%1%{REQUEST_URI} [R=301,L]

    # Step 2 — Upgrade plain HTTP to HTTPS (www already removed above).
    RewriteCond %{HTTPS} off
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

    # Step 3 — Clean URLs (remove .php extension from all page URLs)

    # 3a. /index.php → / (one hop, avoids double-redirect)
    RewriteRule ^index\.php$ / [R=301,L]

    # 3b. /page.php → /page  (301 permanent redirect)
    RewriteCond %{THE_REQUEST} \s/+(.+?)\.php[\s?] [NC]
    RewriteRule ^ /%1 [R=301,L]

    # 3c. /index (extensionless) → / to keep root canonical
    RewriteRule ^index/?$ / [R=301,L]

    # 3d. Internally serve /page as page.php (no redirect, transparent rewrite)
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME}.php -f
    RewriteRule ^([^.]+)/?$ $1.php [L]

</IfModule>

# ── Gzip / Deflate compression ───────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE text/javascript
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/x-javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE image/svg+xml
    AddOutputFilterByType DEFLATE font/woff
    AddOutputFilterByType DEFLATE font/woff2
    AddOutputFilterByType DEFLATE application/font-woff
    AddOutputFilterByType DEFLATE application/font-woff2

    # Remove buggy browser compression signatures
    <IfModule mod_setenvif.c>
        BrowserMatch ^Mozilla/4 gzip-only-text/html
        BrowserMatch ^Mozilla/4\.0[678] no-gzip
        BrowserMatch \bMSIE !no-gzip !gzip-only-text/html
    </IfModule>
</IfModule>

# ── Browser caching (Expires) ────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On

    # HTML — short cache, always re-validate
    ExpiresByType text/html                 "access plus 1 hour"

    # CSS & JS — long cache (use versioned filenames to bust)
    ExpiresByType text/css                  "access plus 1 year"
    ExpiresByType application/javascript    "access plus 1 year"
    ExpiresByType text/javascript           "access plus 1 year"

    # Images
    ExpiresByType image/png                 "access plus 1 year"
    ExpiresByType image/jpeg                "access plus 1 year"
    ExpiresByType image/webp                "access plus 1 year"
    ExpiresByType image/gif                 "access plus 1 year"
    ExpiresByType image/svg+xml             "access plus 1 year"
    ExpiresByType image/x-icon              "access plus 1 year"
    ExpiresByType image/vnd.microsoft.icon  "access plus 1 year"

    # Fonts
    ExpiresByType font/woff                 "access plus 1 year"
    ExpiresByType font/woff2                "access plus 1 year"
    ExpiresByType application/font-woff     "access plus 1 year"
    ExpiresByType application/font-woff2    "access plus 1 year"
</IfModule>

# ── Cache-Control headers ────────────────────────────────────
<IfModule mod_headers.c>
    # Static assets — cache 1 year, treat as immutable
    <FilesMatch "\.(css|js|png|jpg|jpeg|webp|gif|svg|ico|woff|woff2)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

    # PHP pages — always re-validate
    <FilesMatch "\.php$">
        Header set Cache-Control "no-cache, must-revalidate"
        Header set Vary "Accept-Encoding"
    </FilesMatch>

    # Security headers
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ── Remove ETag (redundant with Cache-Control + Expires) ─────
<IfModule mod_headers.c>
    Header unset ETag
</IfModule>
FileETag None

# ── Keep-Alive ───────────────────────────────────────────────
<IfModule mod_headers.c>
    Header set Connection keep-alive
</IfModule>
